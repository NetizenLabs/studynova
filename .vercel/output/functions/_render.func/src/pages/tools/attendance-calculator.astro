---
import Layout from '../../layouts/Layout.astro';
const title = "Free Attendance Calculator for University Students";
---
<Layout title={title}>
  <div class="max-w-4xl mx-auto py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-extrabold text-navy mb-4">Attendance Calculator</h1>
      <p class="text-xl text-gray-600">Track your attendance and find out exactly how many classes you can miss.</p>
    </div>

    <!-- StudyNova Attendance Calculator -->
    <style>
        .nova-attendance {
            max-width: 700px;
            margin: 2rem auto;
            padding: 2rem;
            background: #F7F8FC;
            border-radius: 24px;
            font-family: 'Inter', sans-serif;
            box-shadow: 0 8px 30px rgba(27, 37, 89, 0.08);
            border: 1px solid rgba(79, 124, 255, 0.1);
        }
        .nova-attendance h2 {
            font-family: 'Sora', sans-serif;
            color: #1B2559;
            font-size: 1.8rem;
            margin-top: 0;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .nova-attendance .subtitle {
            color: #4A5568;
            font-size: 0.95rem;
            margin-bottom: 1.5rem;
        }
        .nova-attendance .input-group {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 16px;
        }
        .nova-attendance .input-group label {
            flex: 1;
            min-width: 120px;
            font-weight: 500;
            color: #1B2559;
            font-size: 0.9rem;
        }
        .nova-attendance .input-group input {
            flex: 1;
            min-width: 120px;
            padding: 12px 16px;
            border: 1.5px solid #E2E8F0;
            border-radius: 12px;
            font-size: 1rem;
            background: white;
            transition: 0.2s;
            font-family: 'Inter', sans-serif;
        }
        .nova-attendance .input-group input:focus {
            border-color: #4F7CFF;
            outline: none;
            box-shadow: 0 0 0 3px rgba(79, 124, 255, 0.15);
        }
        .nova-attendance .btn-primary {
            background: #4F7CFF;
            color: white;
            border: none;
            padding: 14px 32px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.2s;
            font-family: 'Inter', sans-serif;
            width: 100%;
            margin-top: 8px;
        }
        .nova-attendance .btn-primary:hover {
            background: #3B5FD9;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(79, 124, 255, 0.3);
        }
        .nova-attendance .result-box {
            background: white;
            padding: 1.5rem;
            border-radius: 16px;
            margin-top: 1.5rem;
            border-left: 5px solid #2EE6A6;
            display: none;
        }
        .nova-attendance .result-box.show {
            display: block;
        }
        .nova-attendance .stat-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin: 12px 0;
        }
        .nova-attendance .stat-item {
            background: #F7F8FC;
            padding: 12px;
            border-radius: 12px;
            text-align: center;
        }
        .nova-attendance .stat-item .number {
            font-family: 'Sora', sans-serif;
            font-size: 2rem;
            font-weight: 700;
            color: #1B2559;
            display: block;
        }
        .nova-attendance .stat-item .label {
            font-size: 0.75rem;
            color: #4A5568;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .nova-attendance .status-badge {
            display: inline-block;
            padding: 6px 18px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.85rem;
            margin-top: 8px;
        }
        .nova-attendance .status-safe { background: #2EE6A6; color: #1B2559; }
        .nova-attendance .status-risk { background: #F6AD55; color: #1B2559; }
        .nova-attendance .status-danger { background: #FC8181; color: #1B2559; }
        .nova-attendance .advice-box {
            background: #EDF2F7;
            padding: 14px;
            border-radius: 12px;
            margin-top: 14px;
            font-size: 0.95rem;
            border-left: 4px solid #4F7CFF;
        }
        .nova-attendance .advice-box strong {
            color: #1B2559;
        }
        @media (max-width: 600px) {
            .nova-attendance .stat-grid {
                grid-template-columns: 1fr;
            }
            .nova-attendance .input-group {
                flex-direction: column;
            }
        }
    </style>

    <div class="nova-attendance">
        <h2>✦ Attendance Calculator</h2>
        <div class="subtitle">Track your attendance percentage and find out exactly how many classes you can miss while staying above the 75% requirement.</div>

        <div class="input-group">
            <label>Total Classes Held</label>
            <input type="number" id="totalClasses" placeholder="e.g., 30" min="1" value="30">
        </div>
        <div class="input-group">
            <label>Classes Attended</label>
            <input type="number" id="attendedClasses" placeholder="e.g., 22" min="0" value="22">
        </div>

        <button class="btn-primary" onclick="calculateAttendance()">Calculate Attendance</button>

        <div class="result-box" id="resultBox">
            <div class="stat-grid">
                <div class="stat-item">
                    <span class="number" id="percentDisplay">0%</span>
                    <span class="label">Attendance</span>
                </div>
                <div class="stat-item">
                    <span class="number" id="statusDisplay">Safe</span>
                    <span class="label">Status</span>
                </div>
            </div>

            <div id="statusBadgeContainer" style="text-align:center;"></div>

            <div class="advice-box" id="adviceBox">
                <strong>📌 Analysis:</strong> <span id="adviceText">Loading...</span>
            </div>

            <div style="margin-top:12px; font-size:0.8rem; color:#718096; text-align:center; border-top:1px solid #EDF2F7; padding-top:12px;">
                <span class="status-safe" style="padding:2px 10px; font-size:0.7rem;">✔ Safe</span> ≥ 75% &nbsp;|&nbsp; 
                <span class="status-risk" style="padding:2px 10px; font-size:0.7rem;">⚠ At Risk</span> 65% – 74% &nbsp;|&nbsp; 
                <span class="status-danger" style="padding:2px 10px; font-size:0.7rem;">✖ Below</span> &lt; 65%
            </div>
        </div>
    </div>

    <script is:inline>
        function calculateAttendance() {
            const total = parseInt(document.getElementById('totalClasses').value);
            const attended = parseInt(document.getElementById('attendedClasses').value);

            // Validation
            if (isNaN(total) || total <= 0) {
                alert('Please enter a valid number for Total Classes (must be greater than 0).');
                return;
            }
            if (isNaN(attended) || attended < 0 || attended > total) {
                alert('Please enter a valid number for Attended Classes (0 to Total).');
                return;
            }

            const percent = (attended / total) * 100;
            const roundedPercent = percent.toFixed(2);

            // --- Analysis Logic ---
            // 1. Status
            let statusText, statusClass;
            if (percent >= 75) {
                statusText = '✅ Safe';
                statusClass = 'status-safe';
            } else if (percent >= 65) {
                statusText = '⚠️ At Risk';
                statusClass = 'status-risk';
            } else {
                statusText = '❌ Below 75%';
                statusClass = 'status-danger';
            }

            // 2. Advice: How many more can you miss to stay at 75%?
            // Formula: Missed = (Attended / 0.75) - Total. If positive, you can miss that many.
            const maxTotalFor75 = attended / 0.75;
            let canMiss = Math.floor(maxTotalFor75 - total);

            let advice = '';
            if (canMiss > 0) {
                advice = `You can miss up to <strong>${canMiss}</strong> more class(es) and still stay above the 75% threshold (assuming no new classes are added).`;
            } else if (canMiss === 0) {
                advice = `You are exactly at the minimum threshold. Do not miss any more classes.`;
            } else {
                // Need to attend more classes to reach 75%
                const needed = Math.ceil(4 * (0.75 * total - attended));
                if (needed > 0) {
                    advice = `You are below 75%. You need to attend the next <strong>${needed}</strong> class(es) without missing any to reach the 75% threshold.`;
                } else {
                    advice = `You are very close. Ensure you don't miss any upcoming classes.`;
                }
            }

            // Display Results
            document.getElementById('percentDisplay').textContent = roundedPercent + '%';
            document.getElementById('statusDisplay').textContent = statusText.replace(/[✅⚠️❌]/g, '').trim();

            const badgeContainer = document.getElementById('statusBadgeContainer');
            badgeContainer.innerHTML = `<span class="status-badge ${statusClass}">${statusText}</span>`;

            document.getElementById('adviceText').innerHTML = advice;

            // Show the box
            document.getElementById('resultBox').classList.add('show');
        }

        // Run on load with default values (30, 22) to show immediate result
        window.addEventListener('DOMContentLoaded', function() {
            calculateAttendance();
        });
    </script>
  </div>
</Layout>
