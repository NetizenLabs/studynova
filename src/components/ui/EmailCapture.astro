---
---

<div class="bg-navy text-white rounded-[2rem] p-8 md:p-12 relative overflow-hidden max-w-4xl mx-auto shadow-2xl mt-16 mb-8">
  <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-white via-transparent to-transparent pointer-events-none"></div>
  
  <div class="relative z-10 grid md:grid-cols-2 gap-8 items-center">
    <div>
      <span class="inline-block bg-white/10 text-mint text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4 border border-white/10">Free Resource</span>
      <h3 class="font-sora text-3xl md:text-4xl font-bold mb-4">Get the Ultimate Study Pack</h3>
      <p class="text-gray-300 mb-6">
        Join our newsletter and download the exact templates we use to organize our semesters. Includes Notion dashboards and printable planners.
      </p>
      <ul class="space-y-2 mb-8 text-sm text-gray-300">
        <li class="flex items-center gap-2">
          <svg class="text-mint w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          Weekly Time Blocking Template
        </li>
        <li class="flex items-center gap-2">
          <svg class="text-mint w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          Exam Revision Checklist
        </li>
      </ul>
    </div>
    
    <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm">
      <form class="flex flex-col gap-4">
        <div>
          <label for="first_name" class="sr-only">First Name</label>
          <input 
            type="text" 
            id="first_name" 
            name="first_name" 
            placeholder="First Name" 
            required
            class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-mint focus:border-transparent transition-all"
          />
        </div>
        <div>
          <label for="email" class="sr-only">Email Address</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            placeholder="Email Address" 
            required
            class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-mint focus:border-transparent transition-all"
          />
        </div>
        <button 
          type="submit" 
          class="bg-mint text-navy w-full py-3.5 rounded-xl font-bold text-lg hover:bg-white transition-all duration-200 active:scale-95 shadow-[0_0_20px_rgba(46,230,166,0.3)] mt-2"
        >
          Send me the pack
        </button>
        <p class="text-center text-xs text-gray-400 mt-2">No spam. Unsubscribe anytime.</p>
      </form>
    </div>
  </div>
</div>
