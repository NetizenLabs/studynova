---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
---

<Layout title="StudyNova Printables - Planners & Trackers">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    
    <div class="text-center mb-20 max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-black text-[#0a2351] tracking-tight mb-6">StudyNova Printables</h1>
      <p class="text-xl text-gray-500 leading-relaxed">Instantly download our meticulously designed PDF planners and trackers to organize your entire academic life.</p>
    </div>

    <!-- Free Printables Section -->
    <div class="mb-24">
      <div class="flex items-center gap-4 mb-10">
        <h2 class="text-3xl font-bold text-[#0a2351]">Free Downloads</h2>
        <div class="h-px bg-gray-200 flex-grow"></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Weekly Study Planner -->
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden flex flex-col md:flex-row">
          <div class="bg-blue-50 md:w-2/5 p-8 flex items-center justify-center">
            <div class="w-full aspect-[3/4] bg-white rounded shadow-md flex items-center justify-center border border-gray-200">
              <span class="text-4xl">📅</span>
            </div>
          </div>
          <div class="p-8 md:w-3/5 flex flex-col">
            <div class="px-3 py-1 bg-green-100 text-green-700 text-xs font-bold uppercase tracking-wider rounded-full w-max mb-4">100% Free</div>
            <h3 class="text-2xl font-bold text-[#0a2351] mb-2">Weekly Study Planner</h3>
            <p class="text-gray-500 mb-8 flex-grow">Our most popular printable. Time-block your entire week, set your non-negotiables, and visually see your available study hours.</p>
            <a href="/printables/weekly-planner" class="w-full block text-center py-3 bg-[#0a2351] text-white font-bold rounded-xl hover:bg-blue-900 transition-colors shadow-lg shadow-blue-900/20">
              Download PDF
            </a>
          </div>
        </div>

        <!-- Assignment Tracker -->
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden flex flex-col md:flex-row">
          <div class="bg-blue-50 md:w-2/5 p-8 flex items-center justify-center">
            <div class="w-full aspect-[3/4] bg-white rounded shadow-md flex items-center justify-center border border-gray-200">
              <span class="text-4xl">✅</span>
            </div>
          </div>
          <div class="p-8 md:w-3/5 flex flex-col">
            <div class="px-3 py-1 bg-green-100 text-green-700 text-xs font-bold uppercase tracking-wider rounded-full w-max mb-4">100% Free</div>
            <h3 class="text-2xl font-bold text-[#0a2351] mb-2">Assignment Tracker</h3>
            <p class="text-gray-500 mb-8 flex-grow">Never miss a deadline again. Log your assignments, due dates, weightage, and status in one master document.</p>
            <a href="/printables/assignment-tracker" class="w-full block text-center py-3 bg-[#0a2351] text-white font-bold rounded-xl hover:bg-blue-900 transition-colors shadow-lg shadow-blue-900/20">
              Download PDF
            </a>
          </div>
        </div>

        <!-- Cornell Notes Template -->
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden flex flex-col md:flex-row">
          <div class="bg-blue-50 md:w-2/5 p-8 flex items-center justify-center">
            <div class="w-full aspect-[3/4] bg-white rounded shadow-md flex items-center justify-center border border-gray-200">
              <span class="text-4xl">📝</span>
            </div>
          </div>
          <div class="p-8 md:w-3/5 flex flex-col">
            <div class="px-3 py-1 bg-green-100 text-green-700 text-xs font-bold uppercase tracking-wider rounded-full w-max mb-4">100% Free</div>
            <h3 class="text-2xl font-bold text-[#0a2351] mb-2">Cornell Notes Template</h3>
            <p class="text-gray-500 mb-8 flex-grow">The most scientifically backed note-taking system. Includes a cue column, notes area, and summary section.</p>
            <a href="/printables/cornell-notes" class="w-full block text-center py-3 bg-[#0a2351] text-white font-bold rounded-xl hover:bg-blue-900 transition-colors shadow-lg shadow-blue-900/20">
              Download PDF
            </a>
          </div>
        </div>

        <!-- 30-Day Habit Tracker -->
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden flex flex-col md:flex-row">
          <div class="bg-blue-50 md:w-2/5 p-8 flex items-center justify-center">
            <div class="w-full aspect-[3/4] bg-white rounded shadow-md flex items-center justify-center border border-gray-200">
              <span class="text-4xl">✔️</span>
            </div>
          </div>
          <div class="p-8 md:w-3/5 flex flex-col">
            <div class="px-3 py-1 bg-green-100 text-green-700 text-xs font-bold uppercase tracking-wider rounded-full w-max mb-4">100% Free</div>
            <h3 class="text-2xl font-bold text-[#0a2351] mb-2">30-Day Habit Tracker</h3>
            <p class="text-gray-500 mb-8 flex-grow">Build academic consistency. Track your reading, coding, or study habits over an entire month.</p>
            <a href="/printables/habit-tracker" class="w-full block text-center py-3 bg-[#0a2351] text-white font-bold rounded-xl hover:bg-blue-900 transition-colors shadow-lg shadow-blue-900/20">
              Download PDF
            </a>
          </div>
        </div>

        <!-- Pomodoro Session Tracker -->
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden flex flex-col md:flex-row">
          <div class="bg-blue-50 md:w-2/5 p-8 flex items-center justify-center">
            <div class="w-full aspect-[3/4] bg-white rounded shadow-md flex items-center justify-center border border-gray-200">
              <span class="text-4xl">🍅</span>
            </div>
          </div>
          <div class="p-8 md:w-3/5 flex flex-col">
            <div class="px-3 py-1 bg-green-100 text-green-700 text-xs font-bold uppercase tracking-wider rounded-full w-max mb-4">100% Free</div>
            <h3 class="text-2xl font-bold text-[#0a2351] mb-2">Pomodoro Session Tracker</h3>
            <p class="text-gray-500 mb-8 flex-grow">Visually cross off your 25-minute focus blocks. Perfect for visual learners who need to see their daily deep work progress.</p>
            <a href="/printables/pomodoro-tracker" class="w-full block text-center py-3 bg-[#0a2351] text-white font-bold rounded-xl hover:bg-blue-900 transition-colors shadow-lg shadow-blue-900/20">
              Download PDF
            </a>
          </div>
        </div>

        <!-- Project Breakdown Matrix -->
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden flex flex-col md:flex-row">
          <div class="bg-blue-50 md:w-2/5 p-8 flex items-center justify-center">
            <div class="w-full aspect-[3/4] bg-white rounded shadow-md flex items-center justify-center border border-gray-200">
              <span class="text-4xl">🧩</span>
            </div>
          </div>
          <div class="p-8 md:w-3/5 flex flex-col">
            <div class="px-3 py-1 bg-green-100 text-green-700 text-xs font-bold uppercase tracking-wider rounded-full w-max mb-4">100% Free</div>
            <h3 class="text-2xl font-bold text-[#0a2351] mb-2">Project Breakdown Matrix</h3>
            <p class="text-gray-500 mb-8 flex-grow">Deconstruct massive essays or group projects into bite-sized, actionable tasks with micro-deadlines.</p>
            <a href="/printables/project-breakdown" class="w-full block text-center py-3 bg-[#0a2351] text-white font-bold rounded-xl hover:bg-blue-900 transition-colors shadow-lg shadow-blue-900/20">
              Download PDF
            </a>
          </div>
        </div>

        <!-- Daily Study & Gratitude Journal -->
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden flex flex-col md:flex-row">
          <div class="bg-blue-50 md:w-2/5 p-8 flex items-center justify-center">
            <div class="w-full aspect-[3/4] bg-white rounded shadow-md flex items-center justify-center border border-gray-200">
              <span class="text-4xl">📖</span>
            </div>
          </div>
          <div class="p-8 md:w-3/5 flex flex-col">
            <div class="px-3 py-1 bg-green-100 text-green-700 text-xs font-bold uppercase tracking-wider rounded-full w-max mb-4">100% Free</div>
            <h3 class="text-2xl font-bold text-[#0a2351] mb-2">Daily Study Journal</h3>
            <p class="text-gray-500 mb-8 flex-grow">A simple 5-minute morning template to set your daily intentions and prioritize your most critical academic task.</p>
            <a href="/printables/daily-journal" class="w-full block text-center py-3 bg-[#0a2351] text-white font-bold rounded-xl hover:bg-blue-900 transition-colors shadow-lg shadow-blue-900/20">
              Download PDF
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Premium Printables Section -->
    <div>
      <div class="flex items-center gap-4 mb-10">
        <h2 class="text-3xl font-bold text-[#0a2351]">Premium Bundles</h2>
        <div class="h-px bg-gray-200 flex-grow"></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Semester Planner -->
        <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm flex flex-col">
          <div class="w-full aspect-video bg-gradient-to-br from-[#0a2351] to-blue-800 rounded-2xl mb-6 flex items-center justify-center relative overflow-hidden">
            <span class="text-5xl relative z-10">🎯</span>
            <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNmZmZmZmYiIGZpbGwtb3BhY2l0eT0iMC4xIi8+PC9zdmc+')] opacity-30"></div>
          </div>
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-xl font-bold text-[#0a2351]">The Ultimate Semester Planner (4-Page Bundle)</h3>
            <span class="text-xl font-black text-blue-600">$9</span>
          </div>
          <p class="text-gray-500 mb-8 flex-grow">Everything you need to crush the entire semester from day one. Includes grade calculators, macro-schedules, and habit trackers.</p>
          <button class="w-full py-3 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-colors" onclick="alert('Checkout integration coming soon')">
            Buy Now
          </button>
        </div>

        <!-- Exam Revision Planner -->
        <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm flex flex-col">
          <div class="w-full aspect-video bg-gradient-to-br from-indigo-900 to-purple-800 rounded-2xl mb-6 flex items-center justify-center relative overflow-hidden">
            <span class="text-5xl relative z-10">📝</span>
            <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNmZmZmZmYiIGZpbGwtb3BhY2l0eT0iMC4xIi8+PC9zdmc+')] opacity-30"></div>
          </div>
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-xl font-bold text-[#0a2351]">7-Day Exam Revision System</h3>
            <span class="text-xl font-black text-blue-600">$5</span>
          </div>
          <p class="text-gray-500 mb-8 flex-grow">A structured framework to prepare for any major exam in exactly 7 days without pulling a single all-nighter.</p>
          <button class="w-full py-3 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-colors" onclick="alert('Checkout integration coming soon')">
            Buy Now
          </button>
        </div>

        <!-- ADHD Student Productivity Kit -->
        <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm flex flex-col">
          <div class="w-full aspect-video bg-gradient-to-br from-pink-600 to-orange-500 rounded-2xl mb-6 flex items-center justify-center relative overflow-hidden">
            <span class="text-5xl relative z-10">🧠</span>
            <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNmZmZmZmYiIGZpbGwtb3BhY2l0eT0iMC4xIi8+PC9zdmc+')] opacity-30"></div>
          </div>
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-xl font-bold text-[#0a2351]">ADHD Student Productivity Kit</h3>
            <span class="text-xl font-black text-blue-600">$8</span>
          </div>
          <p class="text-gray-500 mb-8 flex-grow">Highly visual, color-coded templates designed specifically to minimize executive dysfunction and overwhelm.</p>
          <button class="w-full py-3 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-colors" onclick="alert('Checkout integration coming soon')">
            Buy Now
          </button>
        </div>

        <!-- Ultimate Thesis Planner -->
        <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm flex flex-col">
          <div class="w-full aspect-video bg-gradient-to-br from-green-700 to-teal-900 rounded-2xl mb-6 flex items-center justify-center relative overflow-hidden">
            <span class="text-5xl relative z-10">🎓</span>
            <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNmZmZmZmYiIGZpbGwtb3BhY2l0eT0iMC4xIi8+PC9zdmc+')] opacity-30"></div>
          </div>
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-xl font-bold text-[#0a2351]">The Ultimate Thesis Planner</h3>
            <span class="text-xl font-black text-blue-600">$12</span>
          </div>
          <p class="text-gray-500 mb-8 flex-grow">A massive 12-page roadmap for graduate students to manage literature reviews, meetings, and writing milestones.</p>
          <button class="w-full py-3 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-colors" onclick="alert('Checkout integration coming soon')">
            Buy Now
          </button>
        </div>
      </div>
    </div>

  </div>
</Layout>
