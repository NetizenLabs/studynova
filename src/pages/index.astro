---
import BaseLayout from '../components/layout/BaseLayout.astro';
import EmailCapture from '../components/ui/EmailCapture.astro';
---

<BaseLayout>
  <div class="text-center py-20 md:py-32">
    <div class="mb-6 inline-block">
      <span class="bg-nova-blue/10 text-nova-blue px-4 py-2 rounded-full font-semibold text-sm tracking-wide">
        SYSTEMS FOR STUDENTS
      </span>
    </div>
    <h1 class="text-5xl md:text-7xl font-extrabold text-navy tracking-tight mb-8">
      Transform Chaos Into <br class="hidden md:block" />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-nova-blue to-violet">
        Academic Success
      </span>
    </h1>
    <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-12">
      StudyNova is your digital productivity ecosystem. Stop random studying. Build a system that guarantees results.
    </p>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="/tools" class="bg-navy text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-nova-blue transition-colors shadow-xl shadow-navy/20">
        Explore Free Tools
      </a>
      <a href="/blog" class="bg-white text-navy border-2 border-gray-200 px-8 py-4 rounded-full font-bold text-lg hover:border-navy transition-colors">
        Read the Blog
      </a>
    </div>
  </div>

  <div class="py-20 border-t border-gray-100">
    <h2 class="text-3xl font-bold text-center text-navy mb-12">Popular Tools</h2>
    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <a href="/tools/gpa-calculator" class="group block p-8 bg-white rounded-3xl border border-gray-100 shadow-sm hover:shadow-xl hover:border-nova-blue/30 transition-all duration-300">
        <div class="w-14 h-14 bg-mint/20 rounded-2xl flex items-center justify-center mb-6 text-2xl group-hover:scale-110 transition-transform">
          📊
        </div>
        <h3 class="text-2xl font-bold text-navy mb-2">GPA Calculator</h3>
        <p class="text-gray-500">Easily calculate your semester GPA. Plan ahead and track your academic progress.</p>
      </a>
      <a href="/tools/study-timer" class="group block p-8 bg-white rounded-3xl border border-gray-100 shadow-sm hover:shadow-xl hover:border-violet/30 transition-all duration-300">
        <div class="w-14 h-14 bg-violet/20 rounded-2xl flex items-center justify-center mb-6 text-2xl group-hover:scale-110 transition-transform">
          ⏱️
        </div>
        <h3 class="text-2xl font-bold text-navy mb-2">Study Timer</h3>
        <p class="text-gray-500">Boost your focus with our Pomodoro-style study timer. Work smarter, not harder.</p>
      </a>
    </div>
  </div>

  <EmailCapture />
</BaseLayout>
