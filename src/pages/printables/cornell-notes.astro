---
import '../../styles/global.css';
import PrintableLayout from '../../layouts/PrintableLayout.astro';
---

<PrintableLayout title="Cornell Notes Template" filename="studynova-cornell-notes.pdf">
    
    <!-- Header Area -->
    <div class="mb-4 flex justify-between items-end border-b-2 border-gray-800 pb-2">
        <div class="w-1/2">
            <h1 class="font-['Outfit'] text-3xl font-black text-gray-900 tracking-tight uppercase">Cornell Notes</h1>
            <div class="flex items-center gap-2 mt-2">
                <span class="text-xs font-bold text-gray-600 uppercase">Topic:</span>
                <div class="border-b border-gray-400 flex-grow h-4"></div>
            </div>
        </div>
        <div class="w-1/3 flex flex-col gap-2">
            <div class="flex items-center gap-2">
                <span class="text-xs font-bold text-gray-600 uppercase">Class:</span>
                <div class="border-b border-gray-400 flex-grow h-4"></div>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-xs font-bold text-gray-600 uppercase">Date:</span>
                <div class="border-b border-gray-400 flex-grow h-4"></div>
            </div>
        </div>
    </div>

    <!-- Main Grid: Cue vs Notes -->
    <div class="flex flex-grow border-2 border-gray-800 rounded-sm overflow-hidden" style="min-height: 700px;">
        
        <!-- Left: Cue Column -->
        <div class="w-[30%] border-r-2 border-gray-800 flex flex-col">
            <div class="bg-gray-100 border-b-2 border-gray-800 px-4 py-2 flex items-center justify-center">
                <span class="text-xs font-bold text-gray-800 uppercase tracking-widest text-center">Keywords / Questions</span>
            </div>
            <div class="flex-grow p-4 relative">
                <!-- Vertical helper line -->
                <div class="absolute left-4 top-4 bottom-4 w-px border-l-2 border-red-300 opacity-30"></div>
            </div>
        </div>

        <!-- Right: Notes Column -->
        <div class="w-[70%] flex flex-col">
            <div class="bg-gray-100 border-b-2 border-gray-800 px-4 py-2 flex items-center justify-center">
                <span class="text-xs font-bold text-gray-800 uppercase tracking-widest text-center">Notes / Main Ideas</span>
            </div>
            <div class="flex-grow flex flex-col p-4 gap-6">
                <!-- Ruled Lines -->
                {Array(28).fill(0).map(() => (
                    <div class="border-b border-gray-300 w-full h-1"></div>
                ))}
            </div>
        </div>

    </div>

    <!-- Bottom: Summary Section -->
    <div class="mt-4 border-2 border-gray-800 rounded-sm h-32 flex flex-col">
        <div class="bg-gray-100 border-b-2 border-gray-800 px-4 py-2 flex justify-between items-center">
            <span class="text-xs font-bold text-gray-800 uppercase tracking-widest">Summary</span>
            <span class="text-[8px] text-gray-400 font-bold uppercase tracking-wider">getstudynova.online</span>
        </div>
        <div class="flex-grow flex flex-col p-4 gap-5">
            <div class="border-b border-gray-300 w-full h-1"></div>
            <div class="border-b border-gray-300 w-full h-1"></div>
            <div class="border-b border-gray-300 w-full h-1"></div>
        </div>
    </div>

</PrintableLayout>
