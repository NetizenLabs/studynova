---
import '../../styles/global.css';
import PrintableLayout from '../../layouts/PrintableLayout.astro';
---

<PrintableLayout title="Pomodoro Session Tracker" filename="studynova-pomodoro-tracker.pdf">
    
    <!-- Header Area -->
    <div class="mb-8 border-b-2 border-gray-800 pb-4 flex justify-between items-end">
        <div>
            <h1 class="font-['Outfit'] text-4xl font-black text-gray-900 tracking-tight uppercase">Pomodoro Tracker</h1>
            <p class="text-gray-500 text-sm font-medium mt-1">25-MINUTE FOCUS SESSIONS</p>
        </div>
        <div class="flex flex-col items-end gap-2">
            <div class="flex items-center gap-2">
                <span class="text-sm font-bold text-gray-600 uppercase tracking-widest">Date:</span>
                <div class="border-b border-gray-400 w-32"></div>
            </div>
            <div class="text-xs text-gray-400 font-bold uppercase tracking-wider">getstudynova.online</div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="space-y-6">
        {Array(5).fill(0).map((_, i) => (
            <div class="border-2 border-gray-800 rounded-xl p-4 bg-white">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-lg font-bold text-gray-800 uppercase tracking-wider">Task {i + 1}:</h2>
                    <div class="border-b border-dotted border-gray-400 flex-grow ml-4"></div>
                </div>
                
                <div class="flex justify-between items-center bg-gray-50 p-4 rounded-lg border border-gray-200">
                    <div class="text-xs font-bold text-gray-500 uppercase tracking-widest w-24">Focus Blocks</div>
                    <div class="flex gap-4 flex-grow justify-center">
                        {Array(8).fill(0).map(() => (
                            <div class="w-10 h-10 rounded-full border-2 border-gray-400 flex items-center justify-center bg-white shadow-sm">
                                <span class="text-gray-200 text-xs">🍅</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        ))}
    </div>

    <!-- Instructions / Notes Footer -->
    <div class="mt-8 border-t-2 border-gray-800 pt-4">
        <h3 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-2">How to use this tracker:</h3>
        <p class="text-xs text-gray-600 leading-relaxed">
            1. Write down your specific tasks for the day.<br/>
            2. For every 25 minutes of uninterrupted deep work (1 Pomodoro), cross out one tomato.<br/>
            3. Take a 5-minute break between each block. After 4 blocks, take a longer 15-30 minute break.
        </p>
    </div>

</PrintableLayout>
